[Unit]
Description=RoonServer daemon
After=network.target

[Service]
Type=simple
Environment="ROON_DATAROOT=/var/lib/roon"
Environment="ROON_ID_DIR=/var/lib/roon"
WorkingDirectory=/var/lib/roon
User=roon
Group=roon
ExecStart=/opt/RoonServer/Server/RoonServer
Restart=on-abort
RestartSec=5

PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/roon

[Install]
WantedBy=multi-user.target
