[Unit]
Description=RoonServer daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment="ROON_DATAROOT=/var/lib/roon"
Environment="ROON_ID_DIR=/var/lib/roon"
User=roon
Group=roon
ExecStart=/opt/RoonServer/Server/RoonServer
Restart=on-abort
RestartSec=5

PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=false
ReadWritePaths=/var/lib/roon

[Install]
WantedBy=multi-user.target
